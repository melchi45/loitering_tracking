server/models/*.onnx
*.pt

# Auto-generated TLS certificates
auto.crt
auto.key

# Backup files
*.bak

# Runtime log files (production log output — written to /var/log/lts or server/logs/)
server/logs/

# Python bytecode cache
ingest-daemon/__pycache__/
**/__pycache__/
*.pyc
