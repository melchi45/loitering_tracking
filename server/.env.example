# ── HTTP Server ──────────────────────────────────────────────────────────────
# TCP port the Express server listens on.
HTTP_PORT=3080

# ── HTTPS / TLS ───────────────────────────────────────────────────────────────
# Set HTTPS_ENABLED=true to start the server over TLS (requires cert + key).
# HTTPS_PORT        : TLS listen port (default 3443; 443 requires root/CAP_NET_BIND_SERVICE)
# SSL_CERT_PATH     : Path to PEM certificate, relative to server/ directory
# SSL_KEY_PATH      : Path to PEM private key, relative to server/ directory
# SSL_CA_PATH       : (optional) CA / intermediate bundle, relative to server/ directory
# HTTP_REDIRECT     : Set true to keep plain HTTP on PORT and issue 301 -> HTTPS
HTTPS_ENABLED=true
HTTPS_PORT=3443
SSL_CERT_PATH=./certs/server.crt
SSL_KEY_PATH=./certs/server.key
# SSL_CA_PATH=./certs/ca.crt
HTTP_REDIRECT=true

# ── Storage Backend ──────────────────────────────────────────────────────────
# DB_TYPE=json    : Default — all data stored in storage/lts.json (no external DB required).
# DB_TYPE=mongodb : Write-through to MongoDB; lts.json still written as warm-standby backup.
DB_TYPE=json

# MongoDB connection URI (required only when DB_TYPE=mongodb).
# Format: mongodb://[user:pass@]host[:port]/dbname[?options]
# Atlas example: mongodb+srv://user:pass@cluster.mongodb.net/lts?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/lts

# Override the database name extracted from MONGODB_URI.
# Useful when the URI points to a shared cluster and the DB name must be specified separately.
MONGODB_DB_NAME=lts

# ── Server Environment ───────────────────────────────────────────────────────
# development : ONNX uses a single intra-op thread (light load, suitable for dev/test servers).
# production  : ONNX thread count = max(2, min(8, CPU_cores / 2)).
NODE_ENV=development

# ── Runtime OS / Node binary selection ──────────────────────────────────────
# SERVER_RUNTIME_OS=auto     : Detect from current OS (win32 -> windows, else linux)
# SERVER_RUNTIME_OS=windows  : Force Windows mode
# SERVER_RUNTIME_OS=linux    : Force Linux mode
# NODE_EXEC                  : Explicit node executable to use on any OS (highest priority)
# NODE_EXEC_WINDOWS          : Node executable for Windows mode
# NODE_EXEC_LINUX            : Node executable for Linux mode
# PYTHON_EXEC                : Explicit python executable to use on any OS (highest priority)
# PYTHON_EXEC_WINDOWS        : Python executable for Windows mode
# PYTHON_EXEC_LINUX          : Python executable for Linux mode
# LTS_SKIP_PYTHON_EXPORT=1   : Skip optional Python-based ONNX export in OS scripts
SERVER_RUNTIME_OS=auto
NODE_EXEC=
NODE_EXEC_WINDOWS=node
NODE_EXEC_LINUX=/usr/bin/node
PYTHON_EXEC=
PYTHON_EXEC_WINDOWS=python
PYTHON_EXEC_LINUX=/usr/bin/python3
LTS_SKIP_PYTHON_EXPORT=0

# powershell
# 1. 기존 캐시 및 잘못 설치된 폴더 제거
# rm -Recurse -Force .\node_modules\, .\package-lock.json
# npm cache clean --force
#
# 2. ONNX Runtime 소스 빌드 환경 변수를 활성화한 뒤 설치
# $env:ONNXRUNTIME_NODE_BUILD_FROM_SOURCE="1"
# npm install onnxruntime-node
#
# Linux / macOS / WSL2 기준
# bash
# rm -rf node_modules package-lock.json
# ONNXRUNTIME_NODE_BUILD_FROM_SOURCE=1 npm install onnxruntime-node
# 방법 2.
# 공식 리포지토리를 통한 수동 로컬 빌드 (우회 통과)만약 방법 1로도 호환성 필터에 걸려 CPU 모드로 받아진다면, 공식 가이드대로 Microsoft 소스코드를 직접 클론하여 컴파일한 뒤 프로젝트에 링크해야 합니다.Visual Studio C++ 빌드 도구와 CMake가 Windows에 설치되어 있는지 확인합니다.터미널에서 아래 명령을 순서대로 실행합니다:
# bash
# 1. 소스코드 다운로드
# git clone --recursive https://github.com
# cd onnxruntime/js/node
#
# 2. 내 시스템의 CUDA 13.3 환경을 타겟으로 로컬 빌드 수행
# npm install --build-from-source
# 코드를 사용할 때는 주의가 필요합니다.빌드가 완료되면 본인의 원래 Node.js 프로젝트 폴더로 이동하여 로컬 패키지로 설치합니다:
# bash
# cd /path/to/your/project
# npm install /path/to/onnxruntime/js/node
# 코드를 사용할 때는 주의가 필요합니다.
# 방법 3.
# 현실적인 추천:
# CUDA 12.8 다운그레이드만약 위 빌드 과정에서 C++ 컴파일러 레이어 에러(nvcc 내부 컴파일 오류 등)가 발생한다면,
# 최신 CUDA 13.3의 컴파일 룰을 오픈소스가 아직 완벽하게 따라가지 못한 상태입니다.
# 이 경우 가장 스트레스가 적은 방법은 CUDA 툴킷을 삭제하고 현재 생태계가 완벽히 지원하는
# 마이너 최상위 버전인 CUDA 12.8(또는 12.x) 버전으로 낮추는 것입니다.
# 버전을 낮추면 별도의 복잡한 컴파일 설정 없이
# npm install onnxruntime-node 명령어 한 줄로 즉시 CUDA 가속을 사용할 수 있게 됩니다.

# ── Server Mode ──────────────────────────────────────────────────────────────
# Selects the operational role of this server process.
#
# combined  (default) — Single-process mode: runs camera capture, AI inference,
#                       WebRTC streaming, and REST API in one process. Backward compatible.
#
# streaming           — Streaming-only mode: captures frames from cameras and forwards
#                       them via HTTP to a remote AI analysis server (ANALYSIS_SERVER_URL).
#                       No local AI models are loaded. WebRTC/REST API still served locally.
#                       Requires: ANALYSIS_SERVER_URL
#
# analysis            — Analysis-only mode: exposes /api/analysis/frame HTTP endpoint.
#                       Receives JPEG frames from streaming servers, runs AI inference,
#                       returns detection/tracking/behavior results. No camera capture.
#                       Does not start WebRTC or camera pipelines.
#
SERVER_MODE=combined

# ── Remote Analysis Server (used when SERVER_MODE=streaming) ─────────────────
# Base URL of the AI analysis server that this streaming server will forward frames to.
# Example: http://192.168.1.50:3001  or  https://ai.internal:3443
# Two-process local setup: run `npm run dev:analysis` in a second terminal and set:
#   ANALYSIS_SERVER_URL=http://localhost:3082
ANALYSIS_SERVER_URL=

# HTTP port used by the analysis server process (npm run analysis / npm run dev:analysis).
# Only used when SERVER_MODE=analysis. The streaming server points to this via ANALYSIS_SERVER_URL.
ANALYSIS_HTTP_PORT=3082

# Timeout (ms) for each frame analysis HTTP request to the analysis server.
# Frames that exceed this timeout are dropped (non-blocking).
# Lower values make the circuit breaker trip faster when the server is slow.
# Recommended: 2000 (2 s) — fast enough to stay responsive, slow enough for GPU inference.
ANALYSIS_REQUEST_TIMEOUT_MS=2000

# Maximum number of in-flight concurrent analysis requests across all cameras.
# With the per-camera latest-frame-wins scheduler, each camera uses one slot.
# Set to at least the number of cameras you expect to run simultaneously.
ANALYSIS_MAX_CONCURRENT=16

# ── ONNX Runtime CUDA ────────────────────────────────────────────────────────
# Set to 1 to enable the CUDA execution provider (requires a CUDA-enabled onnxruntime-node build).
# When enabled: executionProviders=['cuda','cpu'], intraOpNumThreads=1 (GPU handles parallelism).
# Leave 0 (or omit) to use CPU-only inference.
ONNX_CUDA=0

# ── ONNX intra-op thread count per mode ──────────────────────────────────────
# Number of CPU threads used per ONNX inference session.
# 0 = auto (production default: max(2, min(8, CPU_cores / 2))).
# Increase ONNX_THREADS_DEV/PROD for multi-core servers; keep low on edge devices.
ONNX_THREADS_DEV=1
ONNX_THREADS_CUDA=1
ONNX_THREADS_PROD=0

# ── WebRTC Engine ────────────────────────────────────────────────────────────
# Selects the SFU/server used to deliver WebRTC streams to browsers.
# Independent from CAPTURE_BACKEND — you can mix and match.
#
# mediamtx  (default) — External MediaMTX process. Browser receives stream via WHEP
#                       protocol at /api/webrtc/whep/:cameraId (proxied by Node.js).
#                       ICE media (UDP) flows directly between browser and MediaMTX.
#                       Requires MediaMTX to be running (npm run dev starts it automatically).
#
# mediasoup           — mediasoup Node.js SFU library. All WebRTC handled inside Node.js;
#                       no external media server process required.
#                       ffmpeg transcodes each RTSP camera to H.264 RTP → PlainTransport;
#                       browsers connect via WebRtcTransport (DTLS/ICE/SRTP).
#                       Env: SERVER_IP, SERVER_PUBLIC_IP (ICE candidates),
#                            MEDIASOUP_MIN_PORT (40000), MEDIASOUP_MAX_PORT (49999)
#
# werift              — werift pure-TypeScript WebRTC library. Lightweight, no native deps.
#                       Requires: npm install werift  (stub — not yet implemented)
#
WEBRTC_ENGINE=mediamtx

# ── RTSP Capture Backend ─────────────────────────────────────────────────────
# Selects the capture engine used to ingest RTSP camera frames for the AI pipeline.
#
# ingest-daemon (default) — External Python PyAV daemon (ingest_daemon.py, :7070).
#                       The daemon pulls from MediaMTX RTSP loopback
#                       (rtsp://127.0.0.1:MEDIAMTX_RTSP_PORT/{cameraId}) and
#                       POSTs JPEG frames to Node.js via HTTP.
#                       MediaMTX holds ONE connection to the camera; WebRTC (WHEP)
#                       and AI frames share it without a second RTSP pull.
#                       Requires: MediaMTX running + ingest_daemon.py
#                       Config: INGEST_DAEMON_BIN, INGEST_DAEMON_ADDR, INGEST_DAEMON_URL
# mediamtx            — Polls MediaMTX snapshot REST API for JPEG frames.
#                       GET /v3/paths/{id}/get-snapshot → JPEG. No subprocess.
#                       Requires MediaMTX ≥ 1.2.0 with api: yes in mediamtx.yml.
# ffmpeg              — FFmpeg subprocess connects directly to the camera RTSP URL.
#                       Widest codec/OS compatibility. Requires: ffmpeg ≥ 3.4
# gstreamer           — GStreamer pipeline. Lower latency; supports hardware decode
#                       (NVIDIA nvdec, Intel/AMD VA-API).
#                       Requires: gstreamer1.0-tools gstreamer1.0-plugins-*
# pyav                — Python PyAV sidecar. Best CUDA utilisation; future path for
#                       Python-side GPU inference. Requires: pip3 install av Pillow
#
CAPTURE_BACKEND=mediamtx

# RTSP re-publish port exposed by MediaMTX (default 8554).
# Only used when CAPTURE_BACKEND=mediamtx.
MEDIAMTX_RTSP_PORT=8554

# Frame-extraction backend for AI analysis when CAPTURE_BACKEND=mediamtx.
# MediaMTX already decodes the camera stream for WebRTC — this controls how
# the server pulls JPEG frames from MediaMTX for the AI pipeline.
#
#   snapshot  (default) — Poll MediaMTX snapshot REST API.
#                         GET /v3/paths/{id}/get-snapshot → JPEG.
#                         No subprocess. Reuses MediaMTX's decode. Best for most setups.
#                         Requires MediaMTX ≥ 1.2.0, api: yes in mediamtx.yml.
#
#   ffmpeg              — FFmpeg subprocess reads MediaMTX's RTSP re-publish.
#                         ~40 MB RAM + CPU per camera. Use if snapshot API unavailable.
#
#   gstreamer           — GStreamer reads MediaMTX RTSP (GPU hw-decode via nvdec/vaapi).
#                         Best when you need GPU-accelerated decode for many cameras.
#
#   pyav                — Python PyAV reads MediaMTX RTSP (CUDA utilisation).
MEDIAMTX_FRAME_BACKEND=snapshot

# ── GStreamer hardware acceleration (only used when CAPTURE_BACKEND=gstreamer) ──
# auto      : Auto-detect — tries nvdec first, then vaapi, falls back to software
# nvdec     : Force NVIDIA NVDEC hardware decode (requires gstreamer1.0-plugins-bad + CUDA)
# vaapi     : Force Intel/AMD VA-API hardware decode (requires gstreamer1.0-vaapi)
# software  : Software decode only (avdec_h264 / decodebin)
GSTREAMER_HW_ACCEL=auto

# ── PyAV sidecar (only used when CAPTURE_BACKEND=pyav) ───────────────────────
# Path to the Python interpreter that has PyAV and Pillow installed.
# Priority order:
#   1) PYAV_PYTHON_BIN
#   2) PYAV_PYTHON_BIN_WINDOWS / PYAV_PYTHON_BIN_LINUX (by SERVER_RUNTIME_OS)
#   3) PYTHON_EXEC / PYTHON_EXEC_WINDOWS / PYTHON_EXEC_LINUX
PYAV_PYTHON_BIN=
PYAV_PYTHON_BIN_WINDOWS=python
PYAV_PYTHON_BIN_LINUX=/usr/bin/python3
# Hardware accelerator for PyAV decode: none | cuda | vaapi | videotoolbox
PYAV_HW_ACCEL=none

# ── RTSP Camera Defaults ─────────────────────────────────────────────────────
# Default credentials used when auto-discovering ONVIF cameras that have not been
# individually configured. Override per-camera via the REST API or the dashboard.
RTSP_DEFAULT_USERNAME=admin
RTSP_DEFAULT_PASSWORD=

# ── AI Model & Inference ──────────────────────────────────────────────────────
# Path to the YOLOv8 ONNX model file (relative to the server/ directory).
YOLO_MODEL=models/yolov8n.onnx

# Minimum confidence score [0, 1] for a detection to be retained after NMS.
# Lower values increase recall but also false positives.
CONFIDENCE_THRESHOLD=0.45

# IoU threshold [0, 1] for Non-Maximum Suppression.
# Overlapping boxes with IoU > this value are merged/suppressed.
NMS_IOU_THRESHOLD=0.5

# ── Loitering Detection Parameters ───────────────────────────────────────────
# Seconds a tracked object must remain in a MONITOR zone before being flagged as loitering.
LOITERING_THRESHOLD_SEC=30

# Minimum pixel displacement between frames to consider an object "moving".
# Objects below this threshold are treated as stationary for dwell-time counting.
MIN_DISPLACEMENT_PX=50

# Seconds within which a re-entering object is linked to the same prior track
# instead of being assigned a new ID.
REENTRY_WINDOW_SEC=120

# Frames without a detection match before a track is considered lost and removed.
MAX_TRACK_AGE_FRAMES=30

# ── Security ──────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens for API authentication.
# MUST be changed to a long random string in production (e.g. openssl rand -hex 32).
JWT_SECRET=change-me-in-production

# ── User Auth (local email + password) ───────────────────────────────────────
# JWT RS256 key pair path (relative to server/ directory).
JWT_PRIVATE_KEY_PATH=./certs/jwt.key
JWT_PUBLIC_KEY_PATH=./certs/jwt.pub

# Access/refresh token expiry.
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cookie signing secret (32+ byte random hex string).
COOKIE_SECRET=change-me-in-production

# CORS allowed origins for credentialed requests (comma-separated).
CLIENT_ORIGIN=https://localhost:3443,http://localhost:3001

# First sign-in with this email (local or OAuth) is automatically granted admin.
ADMIN_SEED_EMAIL=admin@lts.local

# Auth feature flag - set false to disable auth and allow all API access.
AUTH_ENABLED=true

# ── Alert Notifications ───────────────────────────────────────────────────────
# Webhook URL to POST a JSON payload when a loitering alert fires (leave empty to disable).
ALERT_WEBHOOK_URL=

# E-mail address to send alert notifications to (leave empty to disable e-mail alerts).
ALERT_EMAIL_TO=

# SMTP server settings (required only when ALERT_EMAIL_TO is set).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── File Storage ──────────────────────────────────────────────────────────────
# Directory where lts.json, snapshots, and face images are persisted.
# Must be writable by the Node.js process.
STORAGE_PATH=./storage

# ── Detection Snapshot Storage ────────────────────────────────────────────────
# SNAPSHOT_ENABLED=false  : Disable all snapshot saving (no I/O overhead)
# SNAPSHOT_INTERVAL_SEC   : Min seconds between periodic snapshots per track
# SNAPSHOT_MAX_PER_CAMERA_DAY : Prune threshold per camera per 24h
# SNAPSHOT_JPEG_QUALITY   : JPEG compression quality 1-100
# SNAPSHOT_MAX_DIMENSION  : Max crop width/height in pixels
SNAPSHOT_ENABLED=true
SNAPSHOT_INTERVAL_SEC=30
SNAPSHOT_MAX_PER_CAMERA_DAY=500
SNAPSHOT_JPEG_QUALITY=70
SNAPSHOT_MAX_DIMENSION=320

# ── FFmpeg / Pipeline Limits ─────────────────────────────────────────────────
# Maximum number of concurrent camera pipelines (RTSPCapture ffmpeg processes).
# YouTube streams add 1 additional ffmpeg (yt-dlp → RTSP) + yt-dlp itself.
# Rule of thumb: 1 pipeline ≈ 1–2 CPU cores at 1080p. Set 0 for unlimited.
MAX_PIPELINES=0

# Frames per second extracted by ffmpeg from each RTSP stream for the AI pipeline.
# Lower values reduce CPU/GPU load; higher values improve detection responsiveness.
# Recommended range: 5–15. Default: 10.
CAPTURE_FPS=10

# ── YouTube Stream Limits ─────────────────────────────────────────────────────
# yt-dlp binary path (auto-detected if empty; set explicitly if not in PATH)
# Use YTDLP_BIN for a single path, or OS-specific overrides below.
YTDLP_BIN=
YTDLP_BIN_WINDOWS=yt-dlp
YTDLP_BIN_LINUX=yt-dlp

# MediaMTX binary path (auto-detected if empty; set explicitly if not in PATH).
# Used by devServer.js to auto-start MediaMTX alongside the Node.js server.
MEDIAMTX_BIN=
MEDIAMTX_BIN_WINDOWS=mediamtx
MEDIAMTX_BIN_LINUX=mediamtx

# ── Ingest Daemon (CAPTURE_BACKEND=ingest-daemon 전용) ───────────────────────
# Python PyAV daemon that pulls frames from MediaMTX RTSP loopback and POSTs
# JPEG buffers to Node.js. startServer.js detects .py extension and launches it
# via PYTHON_EXEC automatically.
# To use the compiled Go binary instead, point to the binary path (no .py extension).
INGEST_DAEMON_BIN=../ingest-daemon/ingest_daemon.py
INGEST_DAEMON_BIN_WINDOWS=..\ingest-daemon\ingest_daemon.py
INGEST_DAEMON_BIN_LINUX=../ingest-daemon/ingest_daemon.py
INGEST_DAEMON_ADDR=:7070
INGEST_DAEMON_URL=http://127.0.0.1:7070

# ── Ingest Daemon 프레임 제어 ─────────────────────────────────────────────────
# AI_FRAME_INTERVAL  : AI 서버로 보낼 프레임 간격 (N번째 decoded 프레임마다 전송).
#   공식: AI fps = 카메라fps / AI_FRAME_INTERVAL  (예: 30fps / 3 = 10fps AI)
#   GPU 여유 시 줄이고(값↓), GPU 부하 높을 때 늘린다(값↑).  기본값: 3
AI_FRAME_INTERVAL=3

# JPEG_QUALITY : ingest-daemon이 AI 서버로 보내는 JPEG 압축 품질 (1-95).
#   낮출수록 네트워크/메모리 부하 감소, 높일수록 감지 정확도 유리.  기본값: 85
JPEG_QUALITY=85
# AI_MAX_WIDTH : AI 입력 JPEG 최대 가로 픽셀 (초과 시 비율 유지 축소).
#   YOLOv8 입력 640×640 이상으로 올려도 감지 품질 향상 없음.  기본값: 640
AI_MAX_WIDTH=640

# RTSP_READ_TIMEOUT : per-packet RTSP 읽기 타임아웃 (초).
#   이 시간 동안 패킷이 없으면 PyAV interrupt_callback이 발동 → 재접속.
#   stimeout(소켓 레벨 30s)과 독립적으로 동작. 기본값: 5
RTSP_READ_TIMEOUT=5

# Maximum number of simultaneous YouTube-sourced RTSP streams.
# Each stream spawns a yt-dlp process + 1 ffmpeg (merge→RTSP); counted separately from MAX_PIPELINES.
YOUTUBE_MAX_STREAMS=2

# Maximum automatic restart attempts per YouTube stream before it is marked as 'error'.
# After this limit the stream must be restarted manually from the dashboard.
YOUTUBE_MAX_RESTARTS=5

# ── WebRTC ICE Configuration ──────────────────────────────────────────────────
# Server IP announced to browsers as the MediaMTX WHEP host candidate.
# IMPORTANT: Set this to the server's actual LAN IP (not 127.0.0.1).
# If left as 127.0.0.1, browsers cannot reach the server directly and ALL
# WebRTC traffic must relay through an external TURN server, causing instability.
# Find your LAN IP with: hostname -I | awk '{print $1}'
# Example (LAN): SERVER_IP=192.168.1.100
SERVER_IP=127.0.0.1

# Optional second announced IP (e.g., a public/external IP).
# Adds an additional host candidate so browsers outside the LAN can also connect.
# Leave empty if the server is not exposed to the public internet.
SERVER_PUBLIC_IP=

# ── STUN servers ─────────────────────────────────────────────────────────────
# Comma-separated list of STUN URIs.
# Used by the browser to discover its reflexive (NAT-translated) IP address.
# Google's public STUN servers are provided as a fallback; add your own for production.
# NOTE: Remove any STUN servers that your environment cannot reach via DNS.
# Unreachable servers cause a 10–15 s ICE gathering timeout on EVERY WebRTC connection.
# Run the in-app ICE Test (Settings → ICE Connectivity Test) to identify failing servers.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# ── TURN server 1 (LAN / primary) ────────────────────────────────────────────
# Relay server for browsers that cannot reach the SFU directly (e.g., symmetric NAT).
# Set to a coturn instance on the same subnet as SERVER_IP.
# Leave empty to disable TURN (WebRTC may fail for some clients behind strict NAT).
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# ── TURN server 2 (public / secondary) ───────────────────────────────────────
# Optional second TURN server for clients accessing from outside the LAN.
# Typically points to the same coturn instance via its public IP (SERVER_PUBLIC_IP).
TURN_URL_2=
TURN_USERNAME_2=
TURN_CREDENTIAL_2=

# ── OAuth 2.0 ─────────────────────────────────────────────────────────────────
# Base URL of THIS server, used to build callback URLs.
# Example: https://localhost:3443
OAUTH_CALLBACK_BASE=https://localhost:3443

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID (Azure AD)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Session secret (OAuth state cookie signing).
SESSION_SECRET=change-me-in-production

# ── Logging (npm run start / production) ──────────────────────────────────────
# LOG_TO_FILE : Write timestamped logs to LOG_DIR.  true=enabled (default), false=stdout only.
LOG_TO_FILE=true

# LOG_DIR : Directory for daily log files (lts-YYYY-MM-DD.log).
#   Requires write permission. One-time setup (root needed):
#     sudo mkdir -p /var/log/lts && sudo chown $USER:$USER /var/log/lts
#   Falls back to <server>/logs/ automatically when /var/log/lts is not writable.
LOG_DIR=/var/log/lts

# LOG_LEVEL : Minimum log level to output and write to file.
#   DEBUG    — all messages including verbose ffmpeg / yt-dlp output
#   INFO     — normal operations (default; hides ffmpeg HLS metadata noise)
#   WARNING  — warnings + errors only
#   ERROR    — errors + critical only
#   CRITICAL — only fatal errors
#   NONE     — suppress all output
LOG_LEVEL=INFO

# LOG_FILTER_PATTERNS : Comma-separated regex strings.
#   Lines matching ANY pattern are suppressed regardless of LOG_LEVEL.
#   Useful for silencing repetitive patterns that survive level filtering.
#   Example (suppress yt-dlp AD cue-point announcements only):
#     LOG_FILTER_PATTERNS=EXT-X-DATERANGE.*PREDICT,EXT-X-CUEPOINT.*PREDICT
#   Leave empty to apply no extra suppression.
LOG_FILTER_PATTERNS=
