PORT=3001

# ── Server Environment ───────────────────────────────────────────────────────
# development : ONNX 1 thread (light, for test/dev server)
# production  : ONNX threads = max(2, min(8, CPU_cores / 2))
NODE_ENV=development

# ── ONNX Runtime CUDA ────────────────────────────────────────────────────────
# Set to 1 to enable CUDA execution provider (requires CUDA-enabled onnxruntime-node build).
# When enabled, executionProviders=['cuda','cpu'] and intraOpNumThreads=1 (GPU handles parallelism).
# Leave 0 (or omit) to use CPU-only mode.
ONNX_CUDA=0

# ── ONNX intra-op thread count per mode ──────────────────────────────────────
# 0 = auto (production default: max(2, min(8, CPU_cores / 2)))
ONNX_THREADS_DEV=1
ONNX_THREADS_CUDA=1
ONNX_THREADS_PROD=0
RTSP_DEFAULT_USERNAME=admin
RTSP_DEFAULT_PASSWORD=
YOLO_MODEL=models/yolov8n.onnx
CONFIDENCE_THRESHOLD=0.45
NMS_IOU_THRESHOLD=0.5
LOITERING_THRESHOLD_SEC=30
MIN_DISPLACEMENT_PX=50
REENTRY_WINDOW_SEC=120
MAX_TRACK_AGE_FRAMES=30
JWT_SECRET=change-me-in-production
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
STORAGE_PATH=./storage
