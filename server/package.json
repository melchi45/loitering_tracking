{
  "name": "lts-server",
  "version": "1.0.0",
  "description": "Loitering Tracking System - Node.js Backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "stop": "fuser -k 3001/tcp || true",
    "restart": "npm run stop && sleep 1 && npm run start",
    "dev": "nodemon",
    "test": "jest --runInBand --passWithNoTests",
    "discover": "node src/scripts/discoverCameras.js",
    "download-models": "node src/scripts/downloadModels.js",
    "health": "node src/scripts/healthCheck.js",
    "ice-test": "node src/scripts/iceTest.js",
    "ice-test:headless": "node src/scripts/iceTest.js --headless"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "jsonwebtoken": "^9.0.2",
    "mediasoup": "^3.14.15",
    "nodemailer": "^6.9.10",
    "onnxruntime-node": "^1.17.3",
    "sharp": "^0.33.2",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "playwright": "^1.60.0"
  }
}
