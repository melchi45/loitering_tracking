{
  "name": "lts-server",
  "version": "1.0.0",
  "description": "Loitering Tracking System - Node.js Backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/scripts/startServer.js",
    "stop": "node src/scripts/stopServer.js",
    "restart": "npm run stop && npm run start",
    "ingest:start": "node src/scripts/startIngestDaemon.js",
    "ingest:stop": "node src/scripts/stopIngestDaemon.js",
    "ingest:restart": "node src/scripts/restartIngestDaemon.js",
    "mcp:start": "node src/scripts/startMcpServer.js",
    "mcp:stop": "node src/scripts/stopMcpServer.js",
    "mcp:restart": "npm run mcp:stop && npm run mcp:start",
    "dev": "node src/scripts/devServer.js",
    "streaming": "node src/scripts/startServer.js",
    "dev:streaming": "node src/scripts/devServer.js",
    "stop:streaming": "node src/scripts/stopServer.js",
    "analysis": "node src/scripts/startServer.js",
    "dev:analysis": "node src/scripts/devServer.js",
    "stop:analysis": "node src/scripts/stopServer.js",
    "build:client": "node src/scripts/buildClient.js",
    "test": "jest --runInBand --passWithNoTests",
    "test:all": "node ../test/run_all.js --skip e2e",
    "test:tc": "node ../test/tc_runner_cli.js",
    "test:report": "node ../test/generate_report.js --skip e2e",
    "setup-env:windows": "powershell -ExecutionPolicy Bypass -File src/scripts/setup-env.windows.ps1",
    "setup-env:linux": "bash src/scripts/setup-env.linux.sh",
    "check-capture-backend:windows": "powershell -ExecutionPolicy Bypass -File src/scripts/ensure-capture-backend.windows.ps1",
    "check-capture-backend:linux": "bash src/scripts/ensure-capture-backend.linux.sh",
    "discover": "node src/scripts/discoverCameras.js",
    "download-models": "node src/scripts/downloadModels.js",
    "download-models:windows": "powershell -ExecutionPolicy Bypass -File src/scripts/downloadModels.windows.ps1",
    "download-models:linux": "bash src/scripts/downloadModels.linux.sh",
    "build-ort-source:windows": "powershell -ExecutionPolicy Bypass -File src/scripts/build-onnxruntime-source.windows.ps1",
    "build-ort-source:windows:insecure": "powershell -ExecutionPolicy Bypass -File src/scripts/build-onnxruntime-source.windows.ps1 -AllowInsecureTlsForFetch",
    "build-ort-source:linux": "bash src/scripts/build-onnxruntime-source.linux.sh",
    "build-ort:auto": "node src/scripts/buildOrtWithCuda.js",
    "build-ort:auto:dry": "node src/scripts/buildOrtWithCuda.js --dry-run",
    "health": "node src/scripts/healthCheck.js",
    "ice-test": "node src/scripts/iceTest.js",
    "ice-test:headless": "node src/scripts/iceTest.js --headless",
    "turn-test": "node src/scripts/turnTest.js",
    "turn-test:headless": "node src/scripts/turnTest.js --headless",
    "install_db": "node src/scripts/installDb.js",
    "check:gpu": "node src/scripts/checkGpuProviders.js"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "fluent-ffmpeg": "^2.1.2",
    "jsonwebtoken": "^9.0.2",
    "mediasoup": "^3.20.3",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "onnxruntime-node": "^1.26.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.7.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "playwright": "^1.60.0"
  }
}
