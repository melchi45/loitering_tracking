{
  "name": "loitering-tracking-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "fuser -k 3080/tcp 2>/dev/null; fuser -k 3443/tcp 2>/dev/null; sleep 1; true",
    "dev": "concurrently --kill-others --names \"SERVER,CLIENT\" --prefix-colors \"cyan,magenta\" \"cd server && npm run dev\" \"cd client && npm run dev\"",
    "install:all": "cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "streaming": "cd server && npm run streaming",
    "analysis": "cd server && npm run analysis",
    "dev:streaming": "cd server && npm run dev:streaming",
    "dev:analysis": "cd server && npm run dev:analysis",
    "stop:streaming": "cd server && npm run stop:streaming",
    "stop:analysis": "cd server && npm run stop:analysis",
    "build:client": "node server/src/scripts/buildClient.js",
    "stop": "cd server && npm run stop",
    "start": "cd server && npm start",
    "restart": "npm run stop --if-present && npm run start",
    "ingest:start": "cd server && npm run ingest:start",
    "ingest:stop": "cd server && npm run ingest:stop",
    "ingest:restart": "cd server && npm run ingest:restart",
    "mcp:start": "cd server && npm run mcp:start",
    "mcp:stop": "cd server && npm run mcp:stop",
    "mcp:restart": "cd server && npm run mcp:restart",
    "dev:server": "cd server && npm run dev",
    "setup": "npm run install:all && npm run build:client",
    "clean": "rm -rf server/node_modules client/node_modules client/dist",
    "check:gpu": "cd server && npm run check:gpu",
    "build-ort:auto": "cd server && npm run build-ort:auto",
    "build-ort:auto:dry": "cd server && npm run build-ort:auto:dry",
    "test:all": "node test/run_all.js --skip e2e",
    "test:tc": "node test/tc_runner_cli.js",
    "test:report": "node test/generate_report.js --skip e2e"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.18.0",
    "ultralytics": "^1.1.1"
  }
}
